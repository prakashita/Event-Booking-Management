APP_ENV=development
MONGODB_URL=mongodb+srv://<user>:<password>@<cluster>/<db>
DB_NAME=eventdb
SECRET_KEY=replace_with_a_long_random_secret

GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/calendar/oauth/callback
GOOGLE_DRIVE_FOLDER_ID=your_event_reports_folder_id
PUBLICATIONS_DRIVE_FOLDER_ID=your_publications_folder_id

DEFAULT_TIMEZONE=UTC
# Comma-separated admin emails; only these get admin on first login. Other roles assigned via Admin Console.
ADMIN_EMAILS=admin1@example.com,admin2@example.com

LOG_LEVEL=INFO
REQUEST_ID_HEADER=X-Request-ID

# JWT token expiry in minutes (default 10080 = 7 days)
# Security: prefer shorter tokens (e.g. 60) with refresh, or 480 (8h) for balance
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated allowed email domains for login (e.g. user@vidyashilp.edu.in)
ALLOWED_EMAIL_DOMAINS=srmap.edu.in,vidyashilp.edu.in,gmail.com

# CORS: Required for Netlify frontend. Set in production.
# Comma-separated explicit origins for CORS
CORS_ORIGINS=http://localhost:5173,https://event-booking-management.netlify.app,https://delicate-rolypoly-9e3ca2.netlify.app
# Regex for Netlify deploy previews (e.g. deploy-preview-123--project.netlify.app)
CORS_ORIGIN_REGEX=^https:\/\/[a-z0-9-]+\.netlify\.app$
