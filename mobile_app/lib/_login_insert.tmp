enum LoginStatusType { idle, loading, success, error }

class _LoginScreenState extends State<LoginScreen> {
  final _baseCtrl = TextEditingController(text: 'http://localhost:8000');
  final _googleSignIn = GoogleSignIn(scopes: ['email', 'profile']);

  LoginStatusType _statusType = LoginStatusType.idle;
  String _statusMessage = '';

  @override
  void dispose() {
    _baseCtrl.dispose();
    super.dispose();
  }

  @override
  Widget build(BuildContext context) {
    final wide = MediaQuery.sizeOf(context).width >= 960;

    return Scaffold(
      body: Stack(
        children: [
          const Positioned(
            left: -110,
            top: 50,
            child: _Orb(
              size: 260,
              colors: [Color(0xFFFFD7B3), Color(0xFFC98A2F)],
            ),
          ),
          const Positioned(
            right: -90,
            bottom: 30,
            child: _Orb(
              size: 210,
              colors: [Color(0x33007BFF), Color(0x220056B3)],
            ),
          ),
          SafeArea(
            child: Center(
              child: ConstrainedBox(
                constraints: const BoxConstraints(maxWidth: 1200),
                child: Padding(
                  padding: const EdgeInsets.symmetric(
                    horizontal: 18,
                    vertical: 22,
                  ),
                  child: wide
                      ? Row(
                          children: [
                            const Expanded(child: HeroCard()),
                            const SizedBox(width: 22),
                            SizedBox(
                              width: 400,
                              child: LoginCard(
                                onSubmit: _submit,
                                onOpenSettings: _openBaseUrlDialog,
                                statusType: _statusType,
                                statusMessage: _statusMessage,
                              ),
                            ),
                          ],
                        )
                      : SingleChildScrollView(
                          child: Column(
                            children: [
                              LoginCard(
                                onSubmit: _submit,
                                onOpenSettings: _openBaseUrlDialog,
                                statusType: _statusType,
                                statusMessage: _statusMessage,
                              ),
                              const SizedBox(height: 20),
                              const HeroCard(),
                            ],
                          ),
                        ),
                ),
              ),
            ),
          ),
        ],
      ),
    );
  }

  Future<void> _submit() async {
    final baseUrl = _baseCtrl.text.trim().replaceAll(RegExp(r'/$'), '');
    if (baseUrl.isEmpty) {
      setState(() {
        _statusType = LoginStatusType.error;
        _statusMessage = 'API base URL is required.';
      });
      return;
    }

    setState(() {
      _statusType = LoginStatusType.loading;
      _statusMessage = 'Signing you in...';
    });

    try {
      final account = await _googleSignIn.signIn();
      if (account == null) {
        setState(() {
          _statusType = LoginStatusType.error;
          _statusMessage = 'Google sign-in was canceled.';
        });
        return;
      }

      final auth = await account.authentication;
      final idToken = auth.idToken;
      if (idToken == null || idToken.isEmpty) {
        setState(() {
          _statusType = LoginStatusType.error;
          _statusMessage = 'Missing Google credential.';
        });
        return;
      }

      final uri = Uri.parse('$baseUrl/api/v1/auth/google');
      final response = await http.post(
        uri,
        headers: {'Content-Type': 'application/json'},
        body: jsonEncode({'token': idToken}),
      );

      dynamic data;
      if (response.body.isNotEmpty) {
        try {
          data = jsonDecode(response.body);
        } catch (_) {
          data = null;
        }
      }

      if (response.statusCode < 200 || response.statusCode >= 300) {
        final detail = data is Map<String, dynamic>
            ? data['detail']?.toString()
            : null;
        throw Exception(detail ?? 'Login failed. Please try again.');
      }

      final payload = data is Map<String, dynamic> ? data : <String, dynamic>{};
      final user = _asMap(payload['user']);
      final accessToken = payload['access_token']?.toString();
      if (accessToken == null || accessToken.isEmpty) {
        throw Exception('Login failed. Missing access token.');
      }

      if (!mounted) {
        return;
      }

      setState(() {
        _statusType = LoginStatusType.success;
        _statusMessage = 'Signed in successfully.';
      });

      widget.onContinue(
        AppSession(
          baseUrl: baseUrl,
          token: accessToken,
          role: (user['role'] ?? 'faculty').toString(),
          name: (user['name'] ?? account.displayName ?? 'User').toString(),
        ),
      );
    } catch (e) {
      if (!mounted) {
        return;
      }
      setState(() {
        _statusType = LoginStatusType.error;
        _statusMessage = e.toString().replaceFirst('Exception: ', '');
      });
    }
  }

  Future<void> _openBaseUrlDialog() async {
    final temp = TextEditingController(text: _baseCtrl.text);
    final value = await showDialog<String>(
      context: context,
      builder: (_) => AlertDialog(
        title: const Text('API Configuration'),
        content: TextField(
          controller: temp,
          decoration: const InputDecoration(
            labelText: 'Backend Base URL',
            hintText: 'http://localhost:8000',
          ),
        ),
        actions: [
          TextButton(
            onPressed: () => Navigator.pop(context),
            child: const Text('Cancel'),
          ),
          FilledButton(
            onPressed: () => Navigator.pop(context, temp.text.trim()),
            child: const Text('Save'),
          ),
        ],
      ),
    );

    if (value == null || value.isEmpty) {
      return;
    }

    setState(() {
      _baseCtrl.text = value;
      if (_statusType == LoginStatusType.error) {
        _statusType = LoginStatusType.idle;
        _statusMessage = '';
      }
    });
  }
}

class LoginCard extends StatelessWidget {
  const LoginCard({
    super.key,
    required this.onSubmit,
    required this.onOpenSettings,
    required this.statusType,
    required this.statusMessage,
  });

  final Future<void> Function() onSubmit;
  final VoidCallback onOpenSettings;
  final LoginStatusType statusType;
  final String statusMessage;

  @override
  Widget build(BuildContext context) {
    final isLoading = statusType == LoginStatusType.loading;
    final statusColor = switch (statusType) {
      LoginStatusType.success => const Color(0xFF1B6B3D),
      LoginStatusType.error => const Color(0xFFA9382A),
      LoginStatusType.loading => const Color(0xFF21509D),
      LoginStatusType.idle => const Color(0xFF666666),
    };

    return Container(
      padding: const EdgeInsets.all(28),
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: BorderRadius.circular(28),
        boxShadow: const [
          BoxShadow(
            color: Color(0x26000000),
            blurRadius: 40,
            offset: Offset(0, 20),
          ),
        ],
      ),
      child: Column(
        crossAxisAlignment: CrossAxisAlignment.start,
        children: [
          Row(
            children: [
              const Expanded(
                child: Text(
                  'WELCOME BACK',
                  style: TextStyle(
                    letterSpacing: 2.4,
                    fontSize: 11,
                    color: Color(0xFF666666),
                  ),
                ),
              ),
              IconButton(
                tooltip: 'API configuration',
                onPressed: onOpenSettings,
                icon: const Icon(Icons.settings_outlined, size: 18),
              ),
            ],
          ),
          const SizedBox(height: 6),
          Text(
            'Login to your account',
            style: GoogleFonts.playfairDisplay(
              fontWeight: FontWeight.w700,
              fontSize: 44,
              color: const Color(0xFF111217),
              height: 1.05,
            ),
          ),
          const SizedBox(height: 12),
          const Text(
            'Sign in to continue scheduling, tracking, and refining every event experience.',
            style: TextStyle(color: Color(0xFF666666), height: 1.5),
          ),
          const SizedBox(height: 16),
          SizedBox(
            width: double.infinity,
            child: FilledButton.icon(
              onPressed: isLoading ? null : onSubmit,
              style: FilledButton.styleFrom(
                backgroundColor: Colors.white,
                foregroundColor: const Color(0xFF333333),
                side: const BorderSide(color: Color(0x330A1A2F)),
                shape: const StadiumBorder(),
                padding: const EdgeInsets.symmetric(vertical: 14),
              ),
              icon: isLoading
                  ? const SizedBox(
                      width: 16,
                      height: 16,
                      child: CircularProgressIndicator(strokeWidth: 2),
                    )
                  : const Icon(Icons.g_mobiledata_rounded, size: 24),
              label: Text(
                isLoading ? 'Signing in...' : 'Continue with Google',
                style: const TextStyle(fontWeight: FontWeight.w700),
              ),
            ),
          ),
          if (statusMessage.isNotEmpty) ...[
            const SizedBox(height: 12),
            Center(
              child: Text(
                statusMessage,
                textAlign: TextAlign.center,
                style: TextStyle(fontSize: 13, color: statusColor),
              ),
            ),
          ],
          const SizedBox(height: 12),
          const Center(
            child: Text(
              'Use your institutional Google account to continue.',
              textAlign: TextAlign.center,
              style: TextStyle(fontSize: 12, color: Color(0xFF666666)),
            ),
          ),
        ],
      ),
    );
  }
}
